{
  "name": "@data-fair/app-form",
  "version": "0.1.6",
  "type": "module",
  "scripts": {
    "dev": "zellij --layout .zellij.kdl",
    "dev-server": "cross-env APP_URL=http://localhost:3000/app/ df-dev-server",
    "dev-app": "vite --port 3000",
    "build": "rm -rf dist && PUBLIC_URL=https://cdn.jsdelivr.net/npm/@data-fair/app-form@${npm_package_version}/dist vite build",
    "build-types": "df-build-types && cp src/config/.type/resolved-schema.json public/config-schema.json",
    "prepublishOnly": "npm run build && npm run build-types",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@data-fair/frame": "^0.18.5",
    "@data-fair/lib-utils": "^1.10.2",
    "@data-fair/lib-vue": "^1.27.2",
    "@data-fair/lib-vuetify": "^2.3.0",
    "@koumoul/vjsf": "^4.3.1",
    "dayjs": "^1.11.20",
    "ofetch": "^1.5.1",
    "vue": "^3.5.33",
    "vuetify": "^4.0.6"
  },
  "devDependencies": {
    "@data-fair/dev-server": "^2.0.24",
    "@data-fair/lib-types-builder": "^1.12.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "cross-env": "^7.0.3",
    "eslint": "^9.18.0",
    "eslint-plugin-vuetify": "^2.4.0",
    "neostandard": "^0.12.0",
    "sass": "^1.71.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.1.10"
  }
}
